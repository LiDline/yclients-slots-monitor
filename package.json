{
  "name": "yclients-slots-monitor",
  "version": "1.0.0",
  "description": "Отслеживание свободных записей в YCLIENTS с уведомлениями об этом в Telegram.",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LiDline/yclients-slots-monitor.git"
  },
  "keywords": [],
  "author": "LiDline",
  "license": "MIT",
  "homepage": "https://github.com/LiDline/yclients-slots-monitor#readme",
  "dependencies": {
    "cron": "^4.4.0",
    "dotenv": "^17.4.2",
    "joi": "^18.2.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.61.1",
    "telegraf": "^4.16.3",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
